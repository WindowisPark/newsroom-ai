# ── 필수 ──
# Anthropic (Claude Sonnet 4.6 + Haiku 4.5)
ANTHROPIC_API_KEY=sk-ant-xxxxx

# ── 선택 ──
# 외부 Postgres(Supabase 등) 를 쓰고 싶을 때만 지정. 비우면 docker-compose 의 로컬 postgres 서비스로 붙음.
# DATABASE_URL=postgresql+asyncpg://postgres.[project-ref]:[password]@aws-0-ap-northeast-2.pooler.supabase.com:6543/postgres

# 뉴스 수집 보조 소스 (없어도 RSS 만으로 동작)
# NEWSAPI_KEY=xxxxx
# NAVER_CLIENT_ID=xxxxx
# NAVER_CLIENT_SECRET=xxxxx

# 수집 주기 (분)
# COLLECT_INTERVAL_MINUTES=15

# 프론트엔드가 호출할 백엔드 URL (브라우저 기준). Fly/Vercel 배포 시 여기를 퍼블릭 URL 로.
# NEXT_PUBLIC_API_URL=http://localhost:8000/api/v1
